SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
PORT=5000
SCHOOL_UPLOAD_LIMIT_MB=5
SESSION_COOKIE_SECURE=1
DB_POOL_RECYCLE_SECONDS=280
DATABASE_URL=postgresql://username:password@localhost:5432/smart_schools_sms

# Nalo Solutions SMS configuration. Get these values from your Nalo account.
SMS_API_URL=https://sms.nalosolutions.com/smsbackend/Resl_Nalo/send-message/
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
NALO_SMS_SENDER_ID=GoldenAge

# For local testing without PostgreSQL, you may temporarily use:
# DATABASE_URL=sqlite:///smart_schools_sms.db
